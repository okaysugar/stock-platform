# mock: use local generated A-share data
# api: use this repo's backend endpoints through Vite proxy or VITE_API_BASE_URL
VITE_STOCK_DATA_SOURCE=api

# In dev, /api is proxied to VITE_API_PROXY_TARGET by vite.config.ts.
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://127.0.0.1:8080

# Real API K-line query range. The app still reveals data one trading day at a time.
VITE_REAL_KLINE_START=2020-01-01
# VITE_REAL_KLINE_END=2026-06-09
